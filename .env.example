# Database Configuration
# For SQLite (development - zero setup):
DATABASE_URL=file:./prisma/dev.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@localhost:5432/job_tracker

# Node Environment
NODE_ENV=development

# Analytics: AI insights (optional, free via Hugging Face)
# Create a *fine-grained* token with "Make calls to Inference Providers" permission:
# https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
# HUGGINGFACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: switch model (default: Qwen/Qwen2.5-7B-Instruct). Uncomment one:
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct-1M
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# HF_MODEL=meta-llama/Llama-3.2-3B-Instruct
# HF_MODEL=google/gemma-2-9b-it
# HF_MODEL=Microsoft/Phi-3-mini-4k-instruct
